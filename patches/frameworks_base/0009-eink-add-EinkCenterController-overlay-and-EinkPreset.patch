+ */
+
+package com.android.systemui.eink;
+
+import android.annotation.SuppressLint;
+import android.content.BroadcastReceiver;
+import android.content.Context;
+import android.content.Intent;
+import android.content.IntentFilter;
+import android.eink.IEinkManager;
+import android.graphics.PixelFormat;
+import android.os.RemoteException;
+import android.os.ServiceManager;
+import android.os.UserHandle;
+import android.provider.Settings;
+import android.util.Log;
+import android.view.Gravity;
+import android.view.LayoutInflater;
+import android.view.MotionEvent;
+import android.view.View;
+import android.view.WindowManager;
+import android.widget.Button;
+import android.widget.LinearLayout;
+import android.widget.TextView;
+
+import com.android.systemui.CoreStartable;
+import com.android.systemui.res.R;
+import com.android.systemui.broadcast.BroadcastDispatcher;
+import com.android.systemui.dagger.SysUISingleton;
+import com.android.systemui.dagger.qualifiers.Main;
+
+import java.util.concurrent.Executor;
+
+import javax.inject.Inject;
+
+import static android.eink.EinkGestureConstants.ACTION_EINK_GESTURE;
+import static android.eink.EinkGestureConstants.EXTRA_GESTURE;
+import static android.eink.EinkGestureConstants.GESTURE_DOUBLE;
+
+/**
+ * CoreStartable that owns the E-Ink Center overlay window.
+ * The window is pre-inflated at boot and shown/hidden on demand via
+ * a broadcast from EinkGestureDetector in PhoneWindowManager.
+ */
+@SysUISingleton
+public class EinkCenterController implements CoreStartable {
+
+    private static final String TAG = "EinkCenterController";
+
+    // Frontlight step sizes
+    private static final int COLD_FINE   = 5;
+    private static final int COLD_COARSE = 20;
+    private static final int WARM_FINE   = 10;
+    private static final int WARM_COARSE = 50;
+
+    // Mode button selected tint (inverted: black bg, white text)
+    private static final int TINT_SELECTED   = 0xFF000000;
+    private static final int TINT_UNSELECTED = 0xFFFFFFFF;
+    private static final int TEXT_SELECTED   = 0xFFFFFFFF;
+    private static final int TEXT_UNSELECTED = 0xFF000000;
+
+    private final Context mContext;
+    private final WindowManager mWindowManager;
+    private final LayoutInflater mLayoutInflater;
+    private final EinkPresetManager mPresetManager;
+    private final BroadcastDispatcher mBroadcastDispatcher;
+    private final Executor mMainExecutor;
+
+    private View mOverlayView;
+    private boolean mShowing = false;
+
+    // Mode buttons in mode order (BALANCED=1, CLEAR=2, SMOOTH=3, SPEED=4)
+    private Button[] mModeButtons;
+
+    @Inject
+    public EinkCenterController(
+            Context context,
+            WindowManager windowManager,
+            LayoutInflater layoutInflater,
+            EinkPresetManager presetManager,
+            BroadcastDispatcher broadcastDispatcher,
+            @Main Executor mainExecutor) {
+        mContext = context;
+        mWindowManager = windowManager;
+        mLayoutInflater = layoutInflater;
+        mPresetManager = presetManager;
+        mBroadcastDispatcher = broadcastDispatcher;
+        mMainExecutor = mainExecutor;
+    }
+
+    @Override
+    public void start() {
+        inflateOverlay();
+        registerReceiver();
+    }
+
+    // -------------------------------------------------------------------------
+    // Overlay lifecycle
+    // -------------------------------------------------------------------------
+
+    @SuppressLint("InflateParams")
+    private void inflateOverlay() {
+        mOverlayView = mLayoutInflater.inflate(R.layout.eink_center_overlay, null);
+        bindControls();
+    }
+
+    private void show() {
+        if (mShowing) return;
+        refreshValues();
+        mWindowManager.addView(mOverlayView, buildLayoutParams());
+        mShowing = true;
+    }
+
+    private void hide() {
+        if (!mShowing) return;
+        mWindowManager.removeView(mOverlayView);
+        mShowing = false;
+    }
+
+    private void toggle() {
+        if (mShowing) hide(); else show();
+    }
+
+    private WindowManager.LayoutParams buildLayoutParams() {
+        WindowManager.LayoutParams lp = new WindowManager.LayoutParams(
+                WindowManager.LayoutParams.MATCH_PARENT,
+                WindowManager.LayoutParams.WRAP_CONTENT,
+                WindowManager.LayoutParams.TYPE_APPLICATION_OVERLAY,
+                WindowManager.LayoutParams.FLAG_NOT_TOUCH_MODAL
+                        | WindowManager.LayoutParams.FLAG_WATCH_OUTSIDE_TOUCH,
+                PixelFormat.TRANSLUCENT);
+        lp.gravity = Gravity.BOTTOM;
+        lp.setTitle("EinkCenter");
+        return lp;
+    }
+
+    // -------------------------------------------------------------------------
+    // Control binding
+    // -------------------------------------------------------------------------
+
+    private void bindControls() {
+        // Close + force refresh header buttons
+        mOverlayView.findViewById(R.id.eink_close_btn)
+                .setOnClickListener(v -> hide());
+        mOverlayView.findViewById(R.id.eink_force_refresh_btn)
+                .setOnClickListener(v -> runOnEink(IEinkManager::forceFullRefresh));
+
+        // Dismiss on outside touch
+        mOverlayView.setOnTouchListener((v, ev) -> {
+            if (ev.getAction() == MotionEvent.ACTION_OUTSIDE) hide();
+            return false;
+        });
+
+        // Cold frontlight
+        mOverlayView.findViewById(R.id.cold_dec_coarse)
+                .setOnClickListener(v -> adjustCold(-COLD_COARSE));
+        mOverlayView.findViewById(R.id.cold_dec)
+                .setOnClickListener(v -> adjustCold(-COLD_FINE));
+        mOverlayView.findViewById(R.id.cold_inc)
+                .setOnClickListener(v -> adjustCold(+COLD_FINE));
+        mOverlayView.findViewById(R.id.cold_inc_coarse)
+                .setOnClickListener(v -> adjustCold(+COLD_COARSE));
+
+        // Warm frontlight
+        mOverlayView.findViewById(R.id.warm_dec_coarse)
+                .setOnClickListener(v -> adjustWarm(-WARM_COARSE));
+        mOverlayView.findViewById(R.id.warm_dec)
+                .setOnClickListener(v -> adjustWarm(-WARM_FINE));
+        mOverlayView.findViewById(R.id.warm_inc)
+                .setOnClickListener(v -> adjustWarm(+WARM_FINE));
+        mOverlayView.findViewById(R.id.warm_inc_coarse)
+                .setOnClickListener(v -> adjustWarm(+WARM_COARSE));
+
+        // Refresh mode buttons
+        mModeButtons = new Button[]{
+            mOverlayView.findViewById(R.id.mode_balanced),
+            mOverlayView.findViewById(R.id.mode_clear),
+            mOverlayView.findViewById(R.id.mode_smooth),
+            mOverlayView.findViewById(R.id.mode_speed),
+        };
+        for (int i = 0; i < mModeButtons.length; i++) {
+            final int mode = i + 1;
+            mModeButtons[i].setOnClickListener(v -> setMode(mode));
+        }
+
+        // Preset buttons (built dynamically)
+        buildPresetButtons();
+    }
+
+    private void buildPresetButtons() {
+        LinearLayout row = mOverlayView.findViewById(R.id.eink_presets_row);
+        row.removeAllViews();
+        int count = mPresetManager.getCount();
+        for (int i = 0; i < count; i++) {
+            String name = mPresetManager.getName(i);
+            if (name == null) continue;
+            Button btn = new Button(mContext);
+            btn.setText(name.toUpperCase());
+            btn.setTextSize(12f);
+            btn.setTextColor(0xFF000000);
+            btn.getBackground().setTint(0xFFFFFFFF);
+            LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
+                    0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f);
+            lp.setMargins(2, 0, 2, 0);
+            btn.setLayoutParams(lp);
+            final int slot = i;
+            btn.setOnClickListener(v -> applyPreset(slot));
+            row.addView(btn);
+        }
+    }
+
+    // -------------------------------------------------------------------------
+    // Value refresh
+    // -------------------------------------------------------------------------
+
+    private void refreshValues() {
+        IEinkManager eink = getEink();
+        if (eink == null) return;
+        try {
+            int cold = eink.getFrontlightCold();
+            int warm = eink.getFrontlightWarm();
+            int mode = eink.getRefreshMode();
+            ((TextView) mOverlayView.findViewById(R.id.cold_value)).setText(String.valueOf(cold));
+            ((TextView) mOverlayView.findViewById(R.id.warm_value)).setText(String.valueOf(warm));
+            updateModeButtons(mode);
+        } catch (RemoteException e) {
+            Log.e(TAG, "refreshValues failed", e);
+        }
+    }
+
+    private void updateModeButtons(int activeMode) {
+        for (int i = 0; i < mModeButtons.length; i++) {
+            boolean selected = (i + 1) == activeMode;
+            mModeButtons[i].getBackground().setTint(selected ? TINT_SELECTED : TINT_UNSELECTED);
+            mModeButtons[i].setTextColor(selected ? TEXT_SELECTED : TEXT_UNSELECTED);
+        }
+    }
+
+    // -------------------------------------------------------------------------
+    // Actions
+    // -------------------------------------------------------------------------
+
+    private void adjustCold(int delta) {
+        IEinkManager eink = getEink();
+        if (eink == null) return;
+        try {
+            int newCold = Math.max(0, Math.min(80, eink.getFrontlightCold() + delta));
+            eink.setFrontlight(newCold, eink.getFrontlightWarm());
+            ((TextView) mOverlayView.findViewById(R.id.cold_value))
+                    .setText(String.valueOf(newCold));
+        } catch (RemoteException e) {
+            Log.e(TAG, "adjustCold failed", e);
+        }
+    }
+
+    private void adjustWarm(int delta) {
+        IEinkManager eink = getEink();
+        if (eink == null) return;
+        try {
+            int newWarm = Math.max(0, Math.min(254, eink.getFrontlightWarm() + delta));
+            eink.setFrontlight(eink.getFrontlightCold(), newWarm);
+            ((TextView) mOverlayView.findViewById(R.id.warm_value))
+                    .setText(String.valueOf(newWarm));
+        } catch (RemoteException e) {
+            Log.e(TAG, "adjustWarm failed", e);
+        }
+    }
+
+    private void setMode(int mode) {
+        runOnEink(e -> e.setRefreshMode(mode));
+        updateModeButtons(mode);
+    }
+
+    private void applyPreset(int slot) {
+        IEinkManager eink = getEink();
+        if (eink == null) return;
+        try {
+            eink.setFrontlight(mPresetManager.getCold(slot), mPresetManager.getWarm(slot));
+            eink.setRefreshMode(mPresetManager.getMode(slot));
+            refreshValues();
+        } catch (RemoteException e) {
+            Log.e(TAG, "applyPreset failed", e);
+        }
+    }
+
+    // -------------------------------------------------------------------------
+    // Broadcast
+    // -------------------------------------------------------------------------
+
+    private void registerReceiver() {
+        IntentFilter filter = new IntentFilter(ACTION_EINK_GESTURE);
+        mBroadcastDispatcher.registerReceiver(mGestureReceiver, filter, mMainExecutor,
+                UserHandle.ALL);
+    }
+
+    private final BroadcastReceiver mGestureReceiver = new BroadcastReceiver() {
+        @Override
+        public void onReceive(Context context, Intent intent) {
+            String gesture = intent.getStringExtra(EXTRA_GESTURE);
+            if (gesture == null) return;
+            if ("OPEN_CENTER".equals(gesture) || GESTURE_DOUBLE.equals(gesture)) {
+                toggle();
+            } else if (gesture.startsWith("APPLY_PRESET:")) {
+                try {
+                    int slot = Integer.parseInt(gesture.substring(13));
+                    applyPreset(slot);
+                } catch (NumberFormatException ignored) {}
+            }
+        }
+    };
+
+    // -------------------------------------------------------------------------
+    // Helpers
+    // -------------------------------------------------------------------------
+
+    private IEinkManager getEink() {
+        return IEinkManager.Stub.asInterface(
+                ServiceManager.getService(android.content.Context.EINK_SERVICE));
+    }
+
+    @FunctionalInterface
+    interface EinkAction {
+        void run(IEinkManager eink) throws RemoteException;
+    }
+
+    private void runOnEink(EinkAction action) {
+        IEinkManager eink = getEink();
+        if (eink == null) return;
+        try {
+            action.run(eink);
+        } catch (RemoteException e) {
+            Log.e(TAG, "EinkManagerService call failed", e);
+        }
+    }
+}
