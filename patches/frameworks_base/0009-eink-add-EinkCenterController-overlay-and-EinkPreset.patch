+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.systemui.eink;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.provider.Settings;
+
+import com.android.systemui.dagger.SysUISingleton;
+
+import javax.inject.Inject;
+
+/**
+ * Loads, saves, and applies named e-ink presets. Each preset is a
+ * {name, cold, warm, mode} tuple persisted in Settings.System.
+ * Slots 0-3 are the built-in defaults and are used when no user value exists.
+ */
+@SysUISingleton
+public class EinkPresetManager {
+
+    static final int MAX_PRESETS = 6;
+
+    private static final String[][] DEFAULTS = {
+        /* name,   cold, warm, mode */
+        {"Day",       "70",  "0", "1"},
+        {"Night",      "0", "120", "3"},
+        {"Reading",   "35",  "40", "3"},
+        {"Focus",     "60",   "0", "4"},
+    };
+
+    private final ContentResolver mCr;
+
+    @Inject
+    EinkPresetManager(Context context) {
+        mCr = context.getContentResolver();
+    }
+
+    public int getCount() {
+        return MAX_PRESETS;
+    }
+
+    public String getName(int slot) {
+        if (slot < DEFAULTS.length) {
+            String stored = Settings.System.getString(mCr, key(slot, "name"));
+            return stored != null ? stored : DEFAULTS[slot][0];
+        }
+        return Settings.System.getString(mCr, key(slot, "name"));
+    }
+
+    public int getCold(int slot) {
+        int def = slot < DEFAULTS.length ? Integer.parseInt(DEFAULTS[slot][1]) : 40;
+        return Settings.System.getInt(mCr, key(slot, "cold"), def);
+    }
+
+    public int getWarm(int slot) {
+        int def = slot < DEFAULTS.length ? Integer.parseInt(DEFAULTS[slot][2]) : 0;
+        return Settings.System.getInt(mCr, key(slot, "warm"), def);
+    }
+
+    public int getMode(int slot) {
+        int def = slot < DEFAULTS.length ? Integer.parseInt(DEFAULTS[slot][3]) : 1;
+        return Settings.System.getInt(mCr, key(slot, "mode"), def);
+    }
+
+    public void save(int slot, String name, int cold, int warm, int mode) {
+        Settings.System.putString(mCr, key(slot, "name"), name);
+        Settings.System.putInt(mCr, key(slot, "cold"), cold);
+        Settings.System.putInt(mCr, key(slot, "warm"), warm);
+        Settings.System.putInt(mCr, key(slot, "mode"), mode);
+    }
+
+    /** Returns true if the slot has a user-saved (non-default) name. */
+    public boolean isUserSlot(int slot) {
+        return slot >= DEFAULTS.length
+                || Settings.System.getString(mCr, key(slot, "name")) != null;
+    }
+
+    private static String key(int slot, String field) {
+        return "eink_preset_" + slot + "_" + field;
+    }
+}
