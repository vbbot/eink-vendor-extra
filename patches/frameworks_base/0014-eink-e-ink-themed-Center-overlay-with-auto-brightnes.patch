diff --git a/packages/SystemUI/res/color/eink_button_text.xml b/packages/SystemUI/res/color/eink_button_text.xml
new file mode 100644
index 000000000000..cf7a6dc444ed
--- /dev/null
+++ b/packages/SystemUI/res/color/eink_button_text.xml
@@ -0,0 +1,7 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!-- Text color companion for @drawable/bg_eink_button. -->
+<selector xmlns:android="http://schemas.android.com/apk/res/android">
+    <item android:state_selected="true" android:color="#FFFFFFFF" />
+    <item android:state_pressed="true" android:color="#FFFFFFFF" />
+    <item android:color="#FF000000" />
+</selector>
diff --git a/packages/SystemUI/res/drawable/bg_eink_button.xml b/packages/SystemUI/res/drawable/bg_eink_button.xml
new file mode 100644
index 000000000000..92861be5c8bf
--- /dev/null
+++ b/packages/SystemUI/res/drawable/bg_eink_button.xml
@@ -0,0 +1,28 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!--
+  Pure black/white pill background for E-Ink Center buttons.
+  - selected or pressed: solid black fill, no stroke
+  - default:             white fill with 2dp black stroke
+  Pair with @color/eink_button_text so the text color flips in step.
+-->
+<selector xmlns:android="http://schemas.android.com/apk/res/android">
+    <item android:state_selected="true">
+        <shape android:shape="rectangle">
+            <solid android:color="#FF000000" />
+            <corners android:radius="6dp" />
+        </shape>
+    </item>
+    <item android:state_pressed="true">
+        <shape android:shape="rectangle">
+            <solid android:color="#FF000000" />
+            <corners android:radius="6dp" />
+        </shape>
+    </item>
+    <item>
+        <shape android:shape="rectangle">
+            <solid android:color="#FFFFFFFF" />
+            <stroke android:width="2dp" android:color="#FF000000" />
+            <corners android:radius="6dp" />
+        </shape>
+    </item>
+</selector>
