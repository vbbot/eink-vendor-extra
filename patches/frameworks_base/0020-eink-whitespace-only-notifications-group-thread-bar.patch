From 14937b18d934a681862e8c8be18ffb87192932a6 Mon Sep 17 00:00:00 2001
From: Vasu Bhatia <git@vbh.ai>
Date: Thu, 30 Apr 2026 23:57:44 +0200
Subject: [PATCH] eink: whitespace-only notifications + group thread bar
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replace the previous flat-list-with-hairlines look with whitespace-only
separation. The 1dp full-width black hairlines at every row's top edge
read as too heavy on EPD against the white shade — they look like
spreadsheet rules rather than paper. Independent notifications now
have NO chrome at all; AOSP's existing notification_divider_height row
spacing alone provides the visual separation, like paragraphs in a
magazine.

Group children keep the 2dp vertical thread bar on the left edge — the
sole visible affordance, communicating "this row belongs to the group
above" like an email-thread or code-fold marker.

Implementation: - NotificationBackgroundView.drawEinkOverlay drops the top-hairline
    drawRect and just draws the thread bar when mIsChildInGroup. The
    unused mEinkHairlineHeightPx field is removed.
  - mIsChildInGroup is plumbed from
    ActivatableNotificationView.updateBackgroundClipping (unchanged
    from the previous iteration).
  - Both render paths in onDraw (legacy and new dismiss-on-hover) call
    drawEinkOverlay so the bar appears regardless of the
    NotificationAddXOnHoverToDismiss flag state.
Change-Id: I2a2a2b0cf1709532c04b4896c3e4f685a31263c5
---
 .../row/ActivatableNotificationView.java      |  3 ++
 .../row/NotificationBackgroundView.java       | 48 +++++++++++++++++++
 2 files changed, 51 insertions(+)

diff --git a/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/ActivatableNotificationView.java b/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/ActivatableNotificationView.java
index 43c09d4e806e..a1fef4190b73 100644
--- a/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/ActivatableNotificationView.java
+++ b/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/ActivatableNotificationView.java
@@ -354,6 +354,9 @@ public abstract class ActivatableNotificationView extends ExpandableOutlineView
 
     protected void updateBackgroundClipping() {
         mBackgroundNormal.setBottomAmountClips(!isChildInGroup());
+        // E-Ink: track group-child state for the left thread bar drawn in
+        // NotificationBackgroundView.onDraw.
+        mBackgroundNormal.setIsChildInGroup(isChildInGroup());
     }
 
     public void setIsBlurSupported(boolean isBlurSupported) {
diff --git a/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/NotificationBackgroundView.java b/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/NotificationBackgroundView.java
index a1987581fab3..c859f24b7082 100644
--- a/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/NotificationBackgroundView.java
+++ b/packages/SystemUI/src/com/android/systemui/statusbar/notification/row/NotificationBackgroundView.java
@@ -52,6 +52,14 @@ import java.util.Arrays;
 public class NotificationBackgroundView extends View implements Dumpable,
         ExpandableNotificationRow.DismissButtonTargetVisibilityListener {
 
+    /** E-Ink: flat-list aesthetic. Group children get a 2dp vertical thread bar on
+     *  the left edge as the group affordance — independent rows get no chrome and
+     *  rely on AOSP row spacing for separation. See drawEinkOverlay and
+     *  setIsChildInGroup. */
+    private final android.graphics.Paint mEinkLinePaint = new android.graphics.Paint();
+    private final float mEinkThreadBarWidthPx;
+    private boolean mIsChildInGroup = false;
+
     private final boolean mDontModifyCorners;
     private Drawable mBackground;
     private int mClipTopAmount;
@@ -94,6 +102,23 @@ public class NotificationBackgroundView extends View implements Dumpable,
                     com.android.internal.R.color.materialColorSurfaceContainerHigh);
         }
         mFocusOverlayStroke = getResources().getDimension(R.dimen.notification_focus_stroke_width);
+        mEinkLinePaint.setColor(android.graphics.Color.BLACK);
+        mEinkLinePaint.setStyle(android.graphics.Paint.Style.FILL);
+        mEinkThreadBarWidthPx = android.util.TypedValue.applyDimension(
+                android.util.TypedValue.COMPLEX_UNIT_DIP, 2f,
+                getResources().getDisplayMetrics());
+    }
+
+    /**
+     * E-Ink: tracks whether the parent notification row is a child of a notification
+     * group. Used in {@link #onDraw} to draw a left-edge vertical thread bar that
+     * communicates the group affordance in the flat-list aesthetic. Plumbed from
+     * {@link ActivatableNotificationView#updateBackgroundClipping}.
+     */
+    public void setIsChildInGroup(boolean isChildInGroup) {
+        if (mIsChildInGroup == isChildInGroup) return;
+        mIsChildInGroup = isChildInGroup;
+        invalidate();
     }
 
     @Override
@@ -121,6 +146,7 @@ public class NotificationBackgroundView extends View implements Dumpable,
 
             if (!NotificationAddXOnHoverToDismiss.isEnabled()) {
                 draw(canvas, mBackground);
+                drawEinkOverlay(canvas);
                 canvas.restore();
                 return;
             }
@@ -139,10 +165,32 @@ public class NotificationBackgroundView extends View implements Dumpable,
                 mBackground.draw(canvas);
             }
 
+            drawEinkOverlay(canvas);
+
             canvas.restore();
         }
     }
 
+    /**
+     * E-Ink: flat-list aesthetic. Independent notifications get NO chrome — separation
+     * comes purely from AOSP's vertical row spacing (notification_divider_height) so
+     * the shade reads like a stack of paragraphs on paper. Group children get a 2dp
+     * vertical thread bar on the left edge as the only visible affordance,
+     * communicating "this row belongs to the group above" — visually links siblings
+     * under a parent summary, like an email-thread or code-fold marker.
+     *
+     * Earlier iterations tried rounded-card borders and full-width 1dp hairlines;
+     * both read as too heavy on EPD against the white shade. Whitespace + a single
+     * subtle vertical cue where it matters reads cleaner.
+     */
+    private void drawEinkOverlay(Canvas canvas) {
+        if (mBackground == null) return;
+        if (mIsChildInGroup) {
+            canvas.drawRect(0f, 0f, mEinkThreadBarWidthPx, getActualHeight(),
+                    mEinkLinePaint);
+        }
+    }
+
     private Path calculateDismissButtonCutoutPath(Rect backgroundBounds) {
         // TODO(b/365585705): Adapt to RTL after the UX design is finalized.
 
