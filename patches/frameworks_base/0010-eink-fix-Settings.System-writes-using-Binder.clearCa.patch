diff --git a/packages/SystemUI/src/com/android/systemui/eink/EinkAutoBrightnessController.java b/packages/SystemUI/src/com/android/systemui/eink/EinkAutoBrightnessController.java
new file mode 100644
index 000000000000..506eb6cca521
--- /dev/null
+++ b/packages/SystemUI/src/com/android/systemui/eink/EinkAutoBrightnessController.java
@@ -0,0 +1,296 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.systemui.eink;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.database.ContentObserver;
+import android.eink.IEinkManager;
+import android.hardware.Sensor;
+import android.hardware.SensorEvent;
+import android.hardware.SensorEventListener;
+import android.hardware.SensorManager;
+import android.hardware.display.DisplayManager;
+import android.os.Handler;
+import android.os.RemoteException;
+import android.os.ServiceManager;
+import android.provider.Settings;
+import android.util.Log;
+import android.view.Display;
+
+import com.android.systemui.CoreStartable;
+import com.android.systemui.dagger.SysUISingleton;
+import com.android.systemui.dagger.qualifiers.Main;
+
+import java.util.concurrent.atomic.AtomicInteger;
+
+import javax.inject.Inject;
+
+/**
+ * Drives cold / warm / keyboard frontlights from the ambient-light sensor when
+ * {@link Settings.System#SCREEN_BRIGHTNESS_MODE} is {@code AUTOMATIC}.
+ * AOSP's own auto-brightness path is silenced in {@code DisplayPowerController}
+ * via {@code ro.eink.auto_owns_brightness=true} so the two systems don't race.
+ *
+ * <h3>Stability</h3>
+ * <ul>
+ *   <li>Lux is smoothed with a moving average over the last 5 samples.</li>
+ *   <li>A new value is only written if the smoothed lux puts cold/warm/kbd into
+ *       a category {@code &gt;= 5 percentage points} away from what we last wrote.</li>
+ *   <li>At most one update every 20 seconds.</li>
+ * </ul>
+ *
+ * <h3>Manual override (suspend)</h3>
+ * On each sensor tick we read the live cold/warm/kbd values via the AIDL service
+ * and compare to what we last wrote. A divergence means someone else (E-Ink Center
+ * +/-, QS slider, preset apply) wrote to the hardware between our updates. We
+ * suspend that light at the current lux value and only resume once the smoothed
+ * lux moves &gt;= 1.5x in either direction (entering a different ambient regime).
+ * No Settings observers are needed — polling on the sensor cadence is plenty fast
+ * and avoids cross-package observer plumbing.
+ *
+ * <h3>Per-light off toggle</h3>
+ * If the user has explicitly toggled a light off via the E-Ink Center icon
+ * ({@code eink_<light>_off=1}), auto skips that light entirely.
+ */
+@SysUISingleton
+public class EinkAutoBrightnessController implements CoreStartable {
+
+    private static final String TAG = "EinkAutoBrightness";
+
+    private static final int   SMOOTHING_SAMPLES   = 5;
+    private static final int   UPDATE_THRESHOLD_PCT = 5;
+    private static final long  MIN_UPDATE_INTERVAL_MS = 20_000L;
+    private static final float SUSPEND_RESUME_RATIO = 1.5f;
+
+    private final Context mContext;
+    private final SensorManager mSensorManager;
+    private final DisplayManager mDisplayManager;
+    private final Handler mMainHandler;
+
+    // Smoothing ring buffer.
+    private final float[] mLuxRing = new float[SMOOTHING_SAMPLES];
+    private int mLuxRingFill = 0;
+    private int mLuxRingHead = 0;
+    private float mSmoothedLux = -1f;
+
+    // Last applied values per light, plus the lux at which we applied them.
+    // -1 means "never written" — first auto tick will always apply.
+    private final AtomicInteger mLastAppliedCold = new AtomicInteger(-1);
+    private final AtomicInteger mLastAppliedWarm = new AtomicInteger(-1);
+    private final AtomicInteger mLastAppliedKbd  = new AtomicInteger(-1);
+    private long mLastUpdateMs = 0L;
+
+    // Suspend state per light. -1 means not suspended; otherwise the lux value
+    // at which suspension started.
+    private float mSuspendBaselineCold = -1f;
+    private float mSuspendBaselineWarm = -1f;
+    private float mSuspendBaselineKbd  = -1f;
+
+    private boolean mSensorRegistered = false;
+    private boolean mAutoEnabled = false;
+
+    @Inject
+    public EinkAutoBrightnessController(
+            Context context,
+            SensorManager sensorManager,
+            DisplayManager displayManager,
+            @Main Handler mainHandler) {
+        mContext = context;
+        mSensorManager = sensorManager;
+        mDisplayManager = displayManager;
+        mMainHandler = mainHandler;
+    }
+
+    @Override
+    public void start() {
+        mContext.getContentResolver().registerContentObserver(
+                Settings.System.getUriFor(Settings.System.SCREEN_BRIGHTNESS_MODE),
+                false, mModeObserver);
+        syncAutoEnabled();
+    }
+
+    private final ContentObserver mModeObserver = new ContentObserver(null) {
+        @Override
+        public void onChange(boolean selfChange) {
+            syncAutoEnabled();
+        }
+    };
+
+    /**
+     * Detect external writes by polling current values vs what we last applied.
+     * Called on each sensor tick — far cheaper than registering Settings observers
+     * for every brightness key (and avoids the SCREEN_BRIGHTNESS_FLOAT key which
+     * isn't actually a Settings.System constant in this AOSP).
+     */
+    private void detectExternalWrites(IEinkManager eink) {
+        try {
+            int currentCold = eink.getFrontlightCold();
+            int currentWarm = eink.getFrontlightWarm();
+            int currentKbd  = eink.getKeyboardBacklight();
+            if (mLastAppliedCold.get() >= 0 && currentCold != mLastAppliedCold.get()) {
+                mSuspendBaselineCold = mSmoothedLux;
+            }
+            if (mLastAppliedWarm.get() >= 0 && currentWarm != mLastAppliedWarm.get()) {
+                mSuspendBaselineWarm = mSmoothedLux;
+            }
+            if (mLastAppliedKbd.get()  >= 0 && currentKbd  != mLastAppliedKbd.get()) {
+                mSuspendBaselineKbd  = mSmoothedLux;
+            }
+        } catch (RemoteException e) {
+            Log.w(TAG, "detectExternalWrites failed", e);
+        }
+    }
+
+    private void syncAutoEnabled() {
+        ContentResolver cr = mContext.getContentResolver();
+        int mode = Settings.System.getInt(cr,
+                Settings.System.SCREEN_BRIGHTNESS_MODE,
+                Settings.System.SCREEN_BRIGHTNESS_MODE_MANUAL);
+        boolean enabled = mode == Settings.System.SCREEN_BRIGHTNESS_MODE_AUTOMATIC;
+        if (enabled == mAutoEnabled) return;
+        mAutoEnabled = enabled;
+        if (enabled) {
+            registerSensor();
+        } else {
+            unregisterSensor();
+            // Reset state so re-enabling later starts fresh.
+            mLuxRingFill = 0;
+            mLuxRingHead = 0;
+            mSmoothedLux = -1f;
+            mSuspendBaselineCold = mSuspendBaselineWarm = mSuspendBaselineKbd = -1f;
+            mLastAppliedCold.set(-1);
+            mLastAppliedWarm.set(-1);
+            mLastAppliedKbd.set(-1);
+            mLastUpdateMs = 0L;
+        }
+    }
+
+    private void registerSensor() {
+        if (mSensorRegistered) return;
+        Sensor light = mSensorManager.getDefaultSensor(Sensor.TYPE_LIGHT);
+        if (light == null) {
+            Log.w(TAG, "No TYPE_LIGHT sensor on this device — auto-brightness disabled.");
+            return;
+        }
+        mSensorManager.registerListener(mSensorListener, light,
+                SensorManager.SENSOR_DELAY_NORMAL, mMainHandler);
+        mSensorRegistered = true;
+    }
+
+    private void unregisterSensor() {
+        if (!mSensorRegistered) return;
+        mSensorManager.unregisterListener(mSensorListener);
+        mSensorRegistered = false;
+    }
+
+    private final SensorEventListener mSensorListener = new SensorEventListener() {
+        @Override
+        public void onSensorChanged(SensorEvent event) {
+            if (!mAutoEnabled) return;
+            if (mDisplayManager.getDisplay(Display.DEFAULT_DISPLAY).getState()
+                    != Display.STATE_ON) {
+                return;
+            }
+            IEinkManager eink = getEink();
+            if (eink == null) return;
+            updateLux(event.values[0]);
+            detectExternalWrites(eink);
+            maybeApply(eink);
+        }
+
+        @Override public void onAccuracyChanged(Sensor sensor, int accuracy) {}
+    };
+
+    private void updateLux(float rawLux) {
+        mLuxRing[mLuxRingHead] = rawLux;
+        mLuxRingHead = (mLuxRingHead + 1) % SMOOTHING_SAMPLES;
+        if (mLuxRingFill < SMOOTHING_SAMPLES) mLuxRingFill++;
+
+        float sum = 0f;
+        for (int i = 0; i < mLuxRingFill; i++) sum += mLuxRing[i];
+        mSmoothedLux = sum / mLuxRingFill;
+
+        // Resume any suspended lights if the user has moved into a new ambient regime.
+        if (mSuspendBaselineCold >= 0f && resumeIfChanged(mSuspendBaselineCold)) {
+            mSuspendBaselineCold = -1f;
+        }
+        if (mSuspendBaselineWarm >= 0f && resumeIfChanged(mSuspendBaselineWarm)) {
+            mSuspendBaselineWarm = -1f;
+        }
+        if (mSuspendBaselineKbd >= 0f && resumeIfChanged(mSuspendBaselineKbd)) {
+            mSuspendBaselineKbd = -1f;
+        }
+    }
+
+    private boolean resumeIfChanged(float baseline) {
+        float bl = Math.max(1f, baseline);
+        float cur = Math.max(1f, mSmoothedLux);
+        float ratio = Math.max(cur / bl, bl / cur);
+        return ratio >= SUSPEND_RESUME_RATIO;
+    }
+
+    private void maybeApply(IEinkManager eink) {
+        long now = System.currentTimeMillis();
+        if (now - mLastUpdateMs < MIN_UPDATE_INTERVAL_MS) return;
+
+        ContentResolver cr = mContext.getContentResolver();
+
+        int[] coldCurve = EinkAutoCurves.readCurve(cr, EinkAutoCurves.Curve.COLD);
+        int[] warmCurve = EinkAutoCurves.readCurve(cr, EinkAutoCurves.Curve.WARM);
+        int[] kbdCurve  = EinkAutoCurves.readCurve(cr, EinkAutoCurves.Curve.KBD);
+
+        int targetCold = EinkAutoCurves.interpolate(coldCurve, mSmoothedLux);
+        int targetWarm = EinkAutoCurves.interpolate(warmCurve, mSmoothedLux);
+        int targetKbd  = EinkAutoCurves.interpolate(kbdCurve,  mSmoothedLux);
+
+        boolean coldOff = isUserOff(cr, "eink_cold_off") || mSuspendBaselineCold >= 0f;
+        boolean warmOff = isUserOff(cr, "eink_warm_off") || mSuspendBaselineWarm >= 0f;
+        boolean kbdOff  = isUserOff(cr, "eink_kbd_off")  || mSuspendBaselineKbd  >= 0f;
+
+        boolean coldChanged = !coldOff
+                && exceedsThreshold(mLastAppliedCold.get(), targetCold);
+        boolean warmChanged = !warmOff
+                && exceedsThreshold(mLastAppliedWarm.get(), targetWarm);
+        boolean kbdChanged  = !kbdOff
+                && exceedsThreshold(mLastAppliedKbd.get(),  targetKbd);
+
+        if (!coldChanged && !warmChanged && !kbdChanged) return;
+
+        try {
+            // Cold + warm share an AIDL call. Only write the ones that changed,
+            // preserving the other.
+            if (coldChanged || warmChanged) {
+                int writeCold = coldChanged ? targetCold : eink.getFrontlightCold();
+                int writeWarm = warmChanged ? targetWarm : eink.getFrontlightWarm();
+                eink.setFrontlight(writeCold, writeWarm);
+                if (coldChanged) mLastAppliedCold.set(targetCold);
+                if (warmChanged) mLastAppliedWarm.set(targetWarm);
+            }
+            if (kbdChanged) {
+                eink.setKeyboardBacklight(targetKbd);
+                mLastAppliedKbd.set(targetKbd);
+            }
+            mLastUpdateMs = now;
+        } catch (RemoteException e) {
+            Log.e(TAG, "Auto-brightness apply failed", e);
+        }
+    }
+
+    private static boolean exceedsThreshold(int last, int target) {
+        if (last < 0) return true; // first apply
+        return Math.abs(target - last) >= UPDATE_THRESHOLD_PCT;
+    }
+
+    private static boolean isUserOff(ContentResolver cr, String key) {
+        return Settings.System.getInt(cr, key, 0) == 1;
+    }
+
+    private IEinkManager getEink() {
+        return IEinkManager.Stub.asInterface(
+                ServiceManager.getService(Context.EINK_SERVICE));
+    }
+}
