@@ -0,0 +1,83 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.systemui.eink;
+
+import android.content.ContentResolver;
+import android.provider.Settings;
+
+/**
+ * Auto-brightness curves and breakpoint constants. Three independent curves
+ * (cold, warm, keyboard) defined at the same eight lux breakpoints, each value
+ * stored separately in Settings.System so the editor can wire one
+ * {@code StepperPreference} per breakpoint.
+ *
+ * <p>Curves go in the *opposite* direction from a normal phone: as ambient lux
+ * increases, the e-ink display reflects more of it and frontlights are needed
+ * less. Cold peaks around 100 lux (typical indoor reading); warm decreases
+ * monotonically to favour amber light at low ambient (eye comfort + circadian);
+ * keyboard tracks ambient with a sharp falloff.
+ */
+public final class EinkAutoCurves {
+
+    private EinkAutoCurves() {}
+
+    /** Lux thresholds. Same for all three curves so the editor stays uniform. */
+    public static final int[] LUX = {0, 5, 30, 100, 300, 1000, 3000, 8000};
+
+    public static final int[] DEFAULT_COLD = {20, 30, 45, 50, 40, 15,  5,  0};
+    public static final int[] DEFAULT_WARM = {70, 60, 45, 30, 15,  5,  0,  0};
+    public static final int[] DEFAULT_KBD  = {60, 50, 25, 10,  5,  0,  0,  0};
+
+    public enum Curve {
+        COLD("eink_auto_cold_", DEFAULT_COLD),
+        WARM("eink_auto_warm_", DEFAULT_WARM),
+        KBD ("eink_auto_kbd_",  DEFAULT_KBD);
+
+        public final String prefix;
+        public final int[] defaults;
+
+        Curve(String prefix, int[] defaults) {
+            this.prefix = prefix;
+            this.defaults = defaults;
+        }
+    }
+
+    /** Settings.System key for one (curve, lux-index) pair. */
+    public static String key(Curve c, int luxIndex) {
+        return c.prefix + LUX[luxIndex];
+    }
+
+    /** Read all eight values for a curve, falling back to defaults. */
+    public static int[] readCurve(ContentResolver cr, Curve c) {
+        int[] values = new int[LUX.length];
+        for (int i = 0; i < LUX.length; i++) {
+            values[i] = Settings.System.getInt(cr, key(c, i), c.defaults[i]);
+        }
+        return values;
+    }
+
+    /** Reset one curve to its built-in defaults. */
+    public static void resetCurve(ContentResolver cr, Curve c) {
+        for (int i = 0; i < LUX.length; i++) {
+            Settings.System.putInt(cr, key(c, i), c.defaults[i]);
+        }
+    }
+
+    /** Linear interpolation: lux → value (0-100 %). */
+    public static int interpolate(int[] curve, float lux) {
+        if (lux <= LUX[0]) return curve[0];
+        if (lux >= LUX[LUX.length - 1]) return curve[LUX.length - 1];
+        for (int i = 0; i < LUX.length - 1; i++) {
+            float lo = LUX[i];
+            float hi = LUX[i + 1];
+            if (lux >= lo && lux <= hi) {
+                float t = (lux - lo) / (hi - lo);
+                return Math.round(curve[i] + t * (curve[i + 1] - curve[i]));
+            }
+        }
+        return curve[LUX.length - 1];
+    }
+}
