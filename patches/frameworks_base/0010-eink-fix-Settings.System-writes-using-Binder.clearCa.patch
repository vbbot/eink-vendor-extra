+    // -------------------------------------------------------------------------
+    // Percentage conversion helpers
+    // -------------------------------------------------------------------------
+
+    private static int coldToPercent(int raw) {
+        return Math.round(raw * 100f / COLD_MAX_HW);
+    }
+
+    private static int coldFromPercent(int pct) {
+        return Math.round(pct * COLD_MAX_HW / 100f);
+    }
+
+    private static int warmToPercent(int raw) {
+        return Math.round(raw * 100f / WARM_MAX_HW);
+    }
+
+    private static int warmFromPercent(int pct) {
+        return Math.round(pct * WARM_MAX_HW / 100f);
+    }
+
