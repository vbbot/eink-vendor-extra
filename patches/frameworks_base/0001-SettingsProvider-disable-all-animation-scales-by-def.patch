From 72e36633ca12a2edf6fac8665d88bb1c6e13e711 Mon Sep 17 00:00:00 2001
From: Vasu Bhatia <git@vbh.ai>
Date: Sun, 26 Apr 2026 21:17:52 +0200
Subject: [PATCH] SettingsProvider: disable all animation scales by default for
 e-ink

Zero out window_animation_scale, transition_animation_scale, and
animator_duration_scale defaults so the e-ink display never has to
render mid-frame animation states, eliminating ghosting artefacts.

Change-Id: I57eca1880286042fce82124934b4cfe12fba691c
---
 packages/SettingsProvider/res/values/defaults.xml             | 4 ++--
 .../src/com/android/providers/settings/DatabaseHelper.java    | 1 +
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/packages/SettingsProvider/res/values/defaults.xml b/packages/SettingsProvider/res/values/defaults.xml
index e054045a0972..73c5829da61b 100644
--- a/packages/SettingsProvider/res/values/defaults.xml
+++ b/packages/SettingsProvider/res/values/defaults.xml
@@ -34,8 +34,8 @@
     <!-- Default screen brightness, from 0 to 255.  102 is 40%. -->
     <integer name="def_screen_brightness">102</integer>
     <bool name="def_screen_brightness_automatic_mode">false</bool>
-    <fraction name="def_window_animation_scale">100%</fraction>
-    <fraction name="def_window_transition_scale">100%</fraction>
+    <fraction name="def_window_animation_scale">0%</fraction>
+    <fraction name="def_window_transition_scale">0%</fraction>
     <bool name="def_haptic_feedback">true</bool>
 
     <bool name="def_bluetooth_on">false</bool>
diff --git a/packages/SettingsProvider/src/com/android/providers/settings/DatabaseHelper.java b/packages/SettingsProvider/src/com/android/providers/settings/DatabaseHelper.java
index a3eab5da1100..fc4c8ea10c87 100644
--- a/packages/SettingsProvider/src/com/android/providers/settings/DatabaseHelper.java
+++ b/packages/SettingsProvider/src/com/android/providers/settings/DatabaseHelper.java
@@ -2165,6 +2165,7 @@ class DatabaseHelper extends SQLiteOpenHelper {
                 R.fraction.def_window_animation_scale, 1);
         loadFractionSetting(stmt, Settings.System.TRANSITION_ANIMATION_SCALE,
                 R.fraction.def_window_transition_scale, 1);
+        loadSetting(stmt, Settings.Global.ANIMATOR_DURATION_SCALE, "0");
     }
 
     private void loadDefaultHapticSettings(SQLiteStatement stmt) {
-- 
2.43.0

