diff --git a/packages/SystemUI/AndroidManifest.xml b/packages/SystemUI/AndroidManifest.xml
index 5cc3fbf30900..44fea591b26c 100644
--- a/packages/SystemUI/AndroidManifest.xml
+++ b/packages/SystemUI/AndroidManifest.xml
@@ -1204,5 +1204,18 @@
             android:exported="true"
             />
 
+        <!-- E-Ink screensaver: solid white moon-and-Zzz dream activated on every lock. -->
+        <service android:name=".eink.screensaver.EinkDreamService"
+            android:exported="true"
+            android:permission="android.permission.BIND_DREAM_SERVICE">
+            <intent-filter>
+                <action android:name="android.service.dreams.DreamService" />
+                <category android:name="android.intent.category.DEFAULT" />
+            </intent-filter>
+            <meta-data
+                android:name="android.service.dream"
+                android:resource="@xml/eink_dream_metadata" />
+        </service>
+
     </application>
 </manifest>
