 create mode 100644 packages/SystemUI/res/drawable-nodpi/ic_eink_moon_zzz.png
 create mode 100644 packages/SystemUI/res/layout/eink_dream.xml
 create mode 100644 packages/SystemUI/res/xml/eink_dream_metadata.xml
