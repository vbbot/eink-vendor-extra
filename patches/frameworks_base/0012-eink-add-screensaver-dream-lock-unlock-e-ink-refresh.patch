diff --git a/packages/SystemUI/src/com/android/systemui/eink/screensaver/EinkDreamService.java b/packages/SystemUI/src/com/android/systemui/eink/screensaver/EinkDreamService.java
new file mode 100644
index 000000000000..2b3919ed7510
--- /dev/null
+++ b/packages/SystemUI/src/com/android/systemui/eink/screensaver/EinkDreamService.java
@@ -0,0 +1,124 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.systemui.eink.screensaver;
+
+import android.content.Context;
+import android.eink.IEinkManager;
+import android.os.Handler;
+import android.os.Looper;
+import android.os.RemoteException;
+import android.os.ServiceManager;
+import android.service.dreams.DreamService;
+import android.util.Log;
+import android.view.Display;
+import android.view.View;
+
+import com.android.systemui.res.R;
+
+/**
+ * E-Ink screensaver: opaque white background with a crescent-moon + Zzz glyph.
+ *
+ * Registered as the device doze component so PMS starts it on every sleep transition
+ * (power button or screen-timeout). The dream forces a full e-ink panel refresh on
+ * entry and exit so the moon frame draws cleanly and is removed cleanly on wake.
+ */
+public class EinkDreamService extends DreamService {
+
+    private static final String TAG = "EinkDreamService";
+
+    /** How long after kicking the panel refresh before we tear ourselves down. The CLEAR
+     *  cycle on this panel takes ~700–900ms; we wait long enough for the panel hardware
+     *  to finish its inversion+redraw before letting the display transition to OFF. */
+    private static final long FINISH_DELAY_MS = 1500;
+
+    private final Handler mHandler = new Handler(Looper.getMainLooper());
+    private boolean mFinishingAfterRender = false;
+
+    @Override
+    public void onAttachedToWindow() {
+        super.onAttachedToWindow();
+
+        // Dream MUST be interactive=true. Non-interactive dreams dismiss on the first input
+        // event, including the power-button key-up that follows the key-down which started
+        // the sleep transition — the dream would auto-wake within ~80ms of starting.
+        // Setting interactive=true makes the dream ignore stray inputs; PhoneWindowManager
+        // intercepts the power button at a higher layer so user wake still works correctly.
+        setInteractive(true);
+        setFullscreen(true);
+        setScreenBright(false);
+
+        setContentView(R.layout.eink_dream);
+
+        View root = findViewById(R.id.eink_dream_root);
+        if (root != null) {
+            root.setLayerType(View.LAYER_TYPE_SOFTWARE, null);
+        }
+    }
+
+    @Override
+    public void onDreamingStarted() {
+        super.onDreamingStarted();
+
+        // PMS started us via the doze flow (canDoze=true). Without requesting a doze
+        // screen state and entering doze, PMS turns the display off — SurfaceFlinger
+        // stops compositing and our moon never reaches the framebuffer. STATE_DOZE
+        // keeps the display in a low-power on state so our content composites once;
+        // from there the e-ink panel preserves the frame natively.
+        if (canDoze()) {
+            setDozeScreenState(Display.STATE_DOZE);
+            startDozing();
+        }
+
+        // Defer the refresh until after the dream's first frame is actually composited.
+        // onDreamingStarted runs before Choreographer's next doFrame; if we kick the
+        // panel now the e-ink driver reads a still-blank framebuffer and writes white.
+        // Posting to the decor view ensures the runnable lands after at least one draw
+        // pass, so the moon is in the surface buffer when the CPLD reads it.
+        View decor = getWindow().getDecorView();
+        decor.post(this::triggerRefreshAndFinish);
+    }
+
+    private void triggerRefreshAndFinish() {
+        forceFullRefresh();
+
+        // Tear the dream down once the panel has finished its CLEAR cycle. Keeping the
+        // dream alive holds DreamManagerService.mDozeWakeLock, which blocks the kernel
+        // from reaching s2idle/mcusysoff and costs ~10× the battery. The e-ink panel
+        // only repaints when the driver is explicitly told to via forceFullRefresh —
+        // SurfaceFlinger composites after our window is gone, but those frames never
+        // reach the panel — so the moon persists naturally through real sleep without
+        // us babysitting it.
+        mHandler.postDelayed(() -> {
+            mFinishingAfterRender = true;
+            finish();
+        }, FINISH_DELAY_MS);
+    }
+
+    @Override
+    public void onDreamingStopped() {
+        // When we finish ourselves the panel already shows the moon and we don't
+        // want a redundant refresh — SurfaceFlinger has just composited a non-dream
+        // frame, and refreshing would push that (lockscreen) onto the panel. Only
+        // refresh when the user wakes the device (the keyguard ghosts the moon
+        // otherwise; the ACTION_USER_PRESENT receiver handles unlock separately).
+        if (!mFinishingAfterRender) {
+            forceFullRefresh();
+        }
+        mHandler.removeCallbacksAndMessages(null);
+        super.onDreamingStopped();
+    }
+
+    private void forceFullRefresh() {
+        IEinkManager eink = IEinkManager.Stub.asInterface(
+                ServiceManager.getService(Context.EINK_SERVICE));
+        if (eink == null) return;
+        try {
+            eink.forceFullRefresh();
+        } catch (RemoteException e) {
+            Log.w(TAG, "forceFullRefresh failed", e);
+        }
+    }
+}
