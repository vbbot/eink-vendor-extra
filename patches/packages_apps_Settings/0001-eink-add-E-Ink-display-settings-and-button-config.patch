@@ -0,0 +1,85 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.app.AlertDialog;
+import android.content.ContentResolver;
+import android.os.Bundle;
+import android.provider.Settings;
+
+import androidx.preference.Preference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * Lists the four built-in e-ink presets. Each row opens {@link EinkPresetEditFragment}
+ * scoped to its slot. A "Reset all" entry restores every preset to its built-in default.
+ */
+public class EinkPresetsFragment extends SettingsPreferenceFragment {
+
+    static final int SLOT_COUNT = 4;
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_presets_list, rootKey);
+
+        for (int i = 0; i < SLOT_COUNT; i++) {
+            final int slot = i;
+            Preference p = findPreference("eink_preset_slot_" + slot);
+            if (p != null) {
+                p.getExtras().putInt(EinkPresetEditFragment.ARG_SLOT, slot);
+                refreshSlotSummary(p, slot);
+            }
+        }
+
+        Preference resetAll = findPreference("eink_presets_reset_all");
+        if (resetAll != null) {
+            resetAll.setOnPreferenceClickListener(p -> { confirmResetAll(); return true; });
+        }
+    }
+
+    @Override
+    public void onResume() {
+        super.onResume();
+        // Re-read after returning from the editor.
+        for (int i = 0; i < SLOT_COUNT; i++) {
+            Preference p = findPreference("eink_preset_slot_" + i);
+            if (p != null) refreshSlotSummary(p, i);
+        }
+    }
+
+    private void refreshSlotSummary(Preference p, int slot) {
+        ContentResolver cr = getContext().getContentResolver();
+        String name = EinkPresetDefaults.getName(getContext(), cr, slot);
+        int cold = EinkPresetDefaults.getCold(cr, slot);
+        int warm = EinkPresetDefaults.getWarm(cr, slot);
+        int kbd  = EinkPresetDefaults.getKbd(cr, slot);
+        int mode = EinkPresetDefaults.getMode(cr, slot);
+        p.setTitle(name);
+        p.setSummary("Cold " + cold + "% · Warm " + warm + " · Kbd " + kbd
+                + " · Mode " + EinkPresetDefaults.modeLabel(mode));
+    }
+
+    private void confirmResetAll() {
+        new AlertDialog.Builder(getContext())
+                .setTitle(R.string.eink_presets_reset_all_title)
+                .setMessage(R.string.eink_presets_reset_all_summary)
+                .setNegativeButton(android.R.string.cancel, null)
+                .setPositiveButton(android.R.string.ok, (d, w) -> {
+                    ContentResolver cr = getContext().getContentResolver();
+                    for (int i = 0; i < SLOT_COUNT; i++) EinkPresetDefaults.resetSlot(cr, i);
+                    onResume();
+                })
+                .show();
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.VIEW_UNKNOWN;
+    }
+}
