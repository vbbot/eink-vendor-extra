+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.app.AlertDialog;
+import android.content.ContentResolver;
+import android.os.Bundle;
+import android.provider.Settings;
+
+import androidx.preference.EditTextPreference;
+import androidx.preference.ListPreference;
+import androidx.preference.Preference;
+import com.android.settings.widget.SeekBarPreference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * Edits a single preset slot (name, cold %, warm, kbd, refresh mode). Slot index is passed
+ * via fragment arguments under {@link #ARG_SLOT}. Each change writes immediately to
+ * Settings.System; the on-screen E-Ink Center reflects updates the next time it opens.
+ */
+public class EinkPresetEditFragment extends SettingsPreferenceFragment
+        implements Preference.OnPreferenceChangeListener {
+
+    public static final String ARG_SLOT = "eink_preset_slot";
+
+    private int mSlot;
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_preset_edit, rootKey);
+
+        Bundle args = getArguments();
+        mSlot = args != null ? args.getInt(ARG_SLOT, 0) : 0;
+
+        ContentResolver cr = getContext().getContentResolver();
+
+        EditTextPreference namePref = findPreference("eink_preset_name");
+        SeekBarPreference coldPref = findPreference("eink_preset_cold");
+        SeekBarPreference warmPref = findPreference("eink_preset_warm");
+        SeekBarPreference kbdPref  = findPreference("eink_preset_kbd");
+        ListPreference modePref    = findPreference("eink_preset_mode");
+        Preference resetPref       = findPreference("eink_preset_reset");
+
+        if (namePref != null) {
+            namePref.setText(EinkPresetDefaults.getName(getContext(), cr, mSlot));
+            namePref.setOnPreferenceChangeListener(this);
+        }
+        if (coldPref != null) {
+            coldPref.setProgress(EinkPresetDefaults.getCold(cr, mSlot));
+            coldPref.setOnPreferenceChangeListener(this);
+        }
+        if (warmPref != null) {
+            warmPref.setProgress(EinkPresetDefaults.getWarm(cr, mSlot));
+            warmPref.setOnPreferenceChangeListener(this);
+        }
+        if (kbdPref != null) {
+            kbdPref.setProgress(EinkPresetDefaults.getKbd(cr, mSlot));
+            kbdPref.setOnPreferenceChangeListener(this);
+        }
+        if (modePref != null) {
+            modePref.setValue(String.valueOf(EinkPresetDefaults.getMode(cr, mSlot)));
+            modePref.setOnPreferenceChangeListener(this);
+        }
+        if (resetPref != null) {
+            resetPref.setOnPreferenceClickListener(p -> { confirmReset(); return true; });
+        }
+
+        getActivity().setTitle(EinkPresetDefaults.getName(getContext(), cr, mSlot));
+    }
+
+    @Override
+    public boolean onPreferenceChange(Preference preference, Object newValue) {
+        ContentResolver cr = getContext().getContentResolver();
+        switch (preference.getKey()) {
+            case "eink_preset_name":
+                String name = (String) newValue;
+                Settings.System.putString(cr,
+                        EinkPresetDefaults.key(mSlot, "name"),
+                        name == null || name.isEmpty() ? null : name);
+                getActivity().setTitle(name == null || name.isEmpty()
+                        ? EinkPresetDefaults.defaultName(getContext(), mSlot) : name);
+                return true;
+            case "eink_preset_cold":
+                Settings.System.putInt(cr,
+                        EinkPresetDefaults.key(mSlot, "cold"), (Integer) newValue);
+                return true;
+            case "eink_preset_warm":
+                Settings.System.putInt(cr,
+                        EinkPresetDefaults.key(mSlot, "warm"), (Integer) newValue);
+                return true;
+            case "eink_preset_kbd":
+                Settings.System.putInt(cr,
+                        EinkPresetDefaults.key(mSlot, "kbd"), (Integer) newValue);
+                return true;
+            case "eink_preset_mode":
+                Settings.System.putInt(cr,
+                        EinkPresetDefaults.key(mSlot, "mode"),
+                        Integer.parseInt((String) newValue));
+                return true;
+        }
+        return false;
+    }
+
+    private void confirmReset() {
+        new AlertDialog.Builder(getContext())
+                .setTitle(R.string.eink_preset_reset_title)
+                .setMessage(R.string.eink_preset_reset_summary)
+                .setNegativeButton(android.R.string.cancel, null)
+                .setPositiveButton(android.R.string.ok, (d, w) -> {
+                    EinkPresetDefaults.resetSlot(getContext().getContentResolver(), mSlot);
+                    // Re-bind preferences with restored values.
+                    onCreatePreferences(null, null);
+                })
+                .show();
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.VIEW_UNKNOWN;
+    }
+}
