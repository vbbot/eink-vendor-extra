@@ -0,0 +1,51 @@
+<?xml version="1.0" encoding="utf-8"?>
+<!-- StepperPreference layout: title row, then a row with [−−] [−] value [+] [++].
+     Mirrors the E-Ink Center stepper UX so users see the same control everywhere. -->
+<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
+    android:layout_width="match_parent"
+    android:layout_height="wrap_content"
+    android:orientation="vertical"
+    android:paddingStart="16dp"
+    android:paddingEnd="16dp"
+    android:paddingTop="12dp"
+    android:paddingBottom="12dp">
+
+    <TextView android:id="@android:id/title"
+        android:layout_width="match_parent"
+        android:layout_height="wrap_content"
+        android:textAppearance="?android:attr/textAppearanceListItem"
+        android:singleLine="true"
+        android:ellipsize="marquee" />
+
+    <LinearLayout
+        android:layout_width="match_parent"
+        android:layout_height="wrap_content"
+        android:orientation="horizontal"
+        android:gravity="center_vertical"
+        android:layout_marginTop="8dp">
+
+        <Button android:id="@+id/stepper_dec_coarse"
+            android:layout_width="52dp" android:layout_height="40dp"
+            android:text="−−" android:textSize="13sp"
+            android:minWidth="0dp" android:padding="0dp" />
+        <Space android:layout_width="4dp" android:layout_height="match_parent" />
+        <Button android:id="@+id/stepper_dec"
+            android:layout_width="52dp" android:layout_height="40dp"
+            android:text="−" android:textSize="20sp"
+            android:minWidth="0dp" android:padding="0dp" />
+        <TextView android:id="@+id/stepper_value"
+            android:layout_width="0dp" android:layout_weight="1"
+            android:layout_height="wrap_content"
+            android:textSize="18sp" android:textStyle="bold"
+            android:gravity="center" />
+        <Button android:id="@+id/stepper_inc"
+            android:layout_width="52dp" android:layout_height="40dp"
+            android:text="+" android:textSize="20sp"
+            android:minWidth="0dp" android:padding="0dp" />
+        <Space android:layout_width="4dp" android:layout_height="match_parent" />
+        <Button android:id="@+id/stepper_inc_coarse"
+            android:layout_width="52dp" android:layout_height="40dp"
+            android:text="++" android:textSize="13sp"
+            android:minWidth="0dp" android:padding="0dp" />
+    </LinearLayout>
+</LinearLayout>
