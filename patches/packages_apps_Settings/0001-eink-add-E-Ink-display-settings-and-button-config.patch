+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.Context;
+import android.eink.IEinkManager;
+import android.os.Bundle;
+import android.os.RemoteException;
+import android.os.ServiceManager;
+import android.util.Log;
+
+import androidx.preference.ListPreference;
+import androidx.preference.Preference;
+import com.android.settings.widget.SeekBarPreference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * E-Ink display settings: refresh mode, cold/warm frontlight, keyboard backlight,
+ * and entry points to button config and preset editor.
+ */
+public class EinkSettingsFragment extends SettingsPreferenceFragment
+        implements Preference.OnPreferenceChangeListener {
+
+    private static final String TAG = "EinkSettingsFragment";
+
+    private static final String KEY_REFRESH_MODE    = "eink_pref_refresh_mode";
+    private static final String KEY_COLD            = "eink_pref_cold";
+    private static final String KEY_WARM            = "eink_pref_warm";
+    private static final String KEY_KBD             = "eink_pref_kbd_backlight";
+    private static final String KEY_BUTTON_CONFIG   = "eink_pref_button_config";
+    private static final String KEY_FORCE_REFRESH   = "eink_pref_force_refresh";
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_display_settings, rootKey);
+
+        ListPreference modePref = findPreference(KEY_REFRESH_MODE);
+        SeekBarPreference coldPref = findPreference(KEY_COLD);
+        SeekBarPreference warmPref = findPreference(KEY_WARM);
+        SeekBarPreference kbdPref  = findPreference(KEY_KBD);
+
+        IEinkManager eink = getEink();
+        if (eink != null) {
+            try {
+                if (modePref != null) modePref.setValue(String.valueOf(eink.getRefreshMode()));
+                if (coldPref != null) coldPref.setProgress(eink.getFrontlightCold());
+                if (warmPref != null) warmPref.setProgress(eink.getFrontlightWarm());
+                if (kbdPref  != null) kbdPref.setProgress(eink.getKeyboardBacklight());
+            } catch (RemoteException e) {
+                Log.e(TAG, "Failed to read eink values", e);
+            }
+        }
+
+        if (modePref != null) modePref.setOnPreferenceChangeListener(this);
+        if (coldPref != null) coldPref.setOnPreferenceChangeListener(this);
+        if (warmPref != null) warmPref.setOnPreferenceChangeListener(this);
+        if (kbdPref  != null) kbdPref.setOnPreferenceChangeListener(this);
+
+        Preference forceRefreshPref = findPreference(KEY_FORCE_REFRESH);
+        if (forceRefreshPref != null) {
+            forceRefreshPref.setOnPreferenceClickListener(p -> {
+                IEinkManager e = getEink();
+                if (e != null) try { e.forceFullRefresh(); } catch (RemoteException ex) { /**/ }
+                return true;
+            });
+        }
+    }
+
+    @Override
+    public boolean onPreferenceChange(Preference preference, Object newValue) {
+        IEinkManager eink = getEink();
+        if (eink == null) return false;
+        try {
+            switch (preference.getKey()) {
+                case KEY_REFRESH_MODE:
+                    eink.setRefreshMode(Integer.parseInt((String) newValue));
+                    break;
+                case KEY_COLD:
+                    eink.setFrontlight((Integer) newValue,
+                            ((SeekBarPreference) findPreference(KEY_WARM)).getProgress());
+                    break;
+                case KEY_WARM:
+                    eink.setFrontlight(
+                            ((SeekBarPreference) findPreference(KEY_COLD)).getProgress(),
+                            (Integer) newValue);
+                    break;
+                case KEY_KBD:
+                    eink.setKeyboardBacklight((Integer) newValue);
+                    break;
+            }
+        } catch (RemoteException e) {
+            Log.e(TAG, "onPreferenceChange failed", e);
+            return false;
+        }
+        return true;
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.VIEW_UNKNOWN;
+    }
+
+    private IEinkManager getEink() {
+        return IEinkManager.Stub.asInterface(
+                ServiceManager.getService(android.content.Context.EINK_SERVICE));
+    }
+}
