+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.Context;
+import android.util.AttributeSet;
+import android.view.View;
+import android.widget.TextView;
+
+import androidx.annotation.NonNull;
+import androidx.preference.Preference;
+import androidx.preference.PreferenceViewHolder;
+
+import com.android.settings.R;
+
+/**
+ * Two-row preference: title up top, then a stepper [−−][−] value [+][++].
+ *
+ * Operates in 0–100 by default with a "%" suffix on the displayed value. Fragments are
+ * responsible for loading the initial value via {@link #setValue} and reacting to changes via
+ * {@link #setOnPreferenceChangeListener}; this class doesn't auto-persist anything.
+ */
+public class StepperPreference extends Preference {
+
+    private static final int FINE   = 1;
+    private static final int COARSE = 10;
+
+    private int mMin = 0;
+    private int mMax = 100;
+    private int mValue = 0;
+    private String mSuffix = "%";
+
+    public StepperPreference(Context context, AttributeSet attrs) {
+        super(context, attrs);
+        setLayoutResource(R.layout.eink_stepper_preference);
+        setSelectable(false);
+    }
+
+    public StepperPreference(Context context) {
+        this(context, null);
+    }
+
+    public void setMin(int min) {
+        mMin = min;
+        if (mValue < mMin) setValue(mMin);
+    }
+
+    public void setMax(int max) {
+        mMax = max;
+        if (mValue > mMax) setValue(mMax);
+    }
+
+    public void setSuffix(String suffix) {
+        mSuffix = suffix == null ? "" : suffix;
+        notifyChanged();
+    }
+
+    public int getValue() {
+        return mValue;
+    }
+
+    public void setValue(int value) {
+        int clamped = clamp(value);
+        if (clamped == mValue) return;
+        mValue = clamped;
+        notifyChanged();
+    }
+
+    @Override
+    public void onBindViewHolder(@NonNull PreferenceViewHolder holder) {
+        super.onBindViewHolder(holder);
+
+        TextView valueText = (TextView) holder.findViewById(R.id.stepper_value);
+        if (valueText != null) valueText.setText(mValue + mSuffix);
+
+        bindStep(holder, R.id.stepper_dec_coarse, -COARSE);
+        bindStep(holder, R.id.stepper_dec,        -FINE);
+        bindStep(holder, R.id.stepper_inc,        +FINE);
+        bindStep(holder, R.id.stepper_inc_coarse, +COARSE);
+    }
+
+    private void bindStep(PreferenceViewHolder holder, int id, int delta) {
+        View v = holder.findViewById(id);
+        if (v == null) return;
+        v.setOnClickListener(b -> {
+            int newVal = clamp(mValue + delta);
+            if (newVal == mValue) return;
+            if (callChangeListener(newVal)) {
+                mValue = newVal;
+                notifyChanged();
+            }
+        });
+    }
+
+    private int clamp(int v) {
+        return Math.max(mMin, Math.min(mMax, v));
+    }
+}
