diff --git a/src/com/android/settings/display/eink/EinkButtonConfigFragment.java b/src/com/android/settings/display/eink/EinkButtonConfigFragment.java
new file mode 100644
index 00000000000..e64333e1fb4
--- /dev/null
+++ b/src/com/android/settings/display/eink/EinkButtonConfigFragment.java
@@ -0,0 +1,104 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.ContentResolver;
+import android.os.Bundle;
+import android.provider.Settings;
+
+import androidx.preference.ListPreference;
+import androidx.preference.Preference;
+import com.android.settings.widget.SeekBarPreference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * Configures the three physical e-ink button gestures and their timing windows.
+ */
+public class EinkButtonConfigFragment extends SettingsPreferenceFragment
+        implements Preference.OnPreferenceChangeListener {
+
+    private static final String KEY_SINGLE    = "eink_pref_btn_single";
+    private static final String KEY_DOUBLE    = "eink_pref_btn_double";
+    private static final String KEY_LONG      = "eink_pref_btn_long";
+    private static final String KEY_DBL_WIN   = "eink_pref_btn_double_window";
+    private static final String KEY_LONG_THR  = "eink_pref_btn_long_threshold";
+
+    // Settings.System keys (must match EinkGestureDetector)
+    private static final String SYS_SINGLE   = "eink_button_single_press";
+    private static final String SYS_DOUBLE   = "eink_button_double_press";
+    private static final String SYS_LONG     = "eink_button_long_press";
+    private static final String SYS_DBL_WIN  = "eink_button_double_press_window_ms";
+    private static final String SYS_LONG_THR = "eink_button_long_press_threshold_ms";
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_button_settings, rootKey);
+
+        ContentResolver cr = requireContext().getContentResolver();
+
+        initListPref(findPreference(KEY_SINGLE), cr, SYS_SINGLE, "FORCE_REFRESH");
+        initListPref(findPreference(KEY_DOUBLE), cr, SYS_DOUBLE, "OPEN_CENTER");
+        initListPref(findPreference(KEY_LONG),   cr, SYS_LONG,   "APPLY_PRESET:1");
+
+        initSeekBar(findPreference(KEY_DBL_WIN),  cr, SYS_DBL_WIN,  350);
+        initSeekBar(findPreference(KEY_LONG_THR), cr, SYS_LONG_THR, 600);
+    }
+
+    private void initListPref(ListPreference pref, ContentResolver cr,
+            String sysKey, String defaultValue) {
+        if (pref == null) return;
+        String stored = Settings.System.getString(cr, sysKey);
+        pref.setValue(stored != null ? stored : defaultValue);
+        pref.setSummary(pref.getEntry());
+        pref.setOnPreferenceChangeListener(this);
+    }
+
+    private void initSeekBar(SeekBarPreference pref, ContentResolver cr,
+            String sysKey, int defaultValue) {
+        if (pref == null) return;
+        pref.setProgress(Settings.System.getInt(cr, sysKey, defaultValue));
+        pref.setOnPreferenceChangeListener(this);
+    }
+
+    @Override
+    public boolean onPreferenceChange(Preference preference, Object newValue) {
+        ContentResolver cr = requireContext().getContentResolver();
+        switch (preference.getKey()) {
+            case KEY_SINGLE:
+                Settings.System.putString(cr, SYS_SINGLE, (String) newValue);
+                updateSummary((ListPreference) preference, (String) newValue);
+                break;
+            case KEY_DOUBLE:
+                Settings.System.putString(cr, SYS_DOUBLE, (String) newValue);
+                updateSummary((ListPreference) preference, (String) newValue);
+                break;
+            case KEY_LONG:
+                Settings.System.putString(cr, SYS_LONG, (String) newValue);
+                updateSummary((ListPreference) preference, (String) newValue);
+                break;
+            case KEY_DBL_WIN:
+                Settings.System.putInt(cr, SYS_DBL_WIN, (Integer) newValue);
+                break;
+            case KEY_LONG_THR:
+                Settings.System.putInt(cr, SYS_LONG_THR, (Integer) newValue);
+                break;
+        }
+        return true;
+    }
+
+    private void updateSummary(ListPreference pref, String value) {
+        pref.setValue(value);
+        pref.setSummary(pref.getEntry());
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.VIEW_UNKNOWN;
+    }
+}
diff --git a/src/com/android/settings/display/eink/EinkPresetDefaults.java b/src/com/android/settings/display/eink/EinkPresetDefaults.java
new file mode 100644
index 00000000000..92a52a6b282
--- /dev/null
+++ b/src/com/android/settings/display/eink/EinkPresetDefaults.java
@@ -0,0 +1,90 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.provider.Settings;
+
+import com.android.settings.R;
+
+/**
+ * Mirrors {@code com.android.systemui.eink.EinkPresetManager} default values and key naming.
+ * Both packages read/write the same Settings.System keys, so they always stay in sync.
+ *
+ * Cold values are display percentage (0-100); warm and kbd are 0-254 hardware units.
+ */
+final class EinkPresetDefaults {
+
+    /** {cold, warm, kbd, mode} — names come from string resources, see defaultName(). */
+    private static final int[][] DEFAULTS = {
+        /* Day     */ { 80,   0,   0, 1 },
+        /* Night   */ { 15, 120, 200, 3 },
+        /* Reading */ { 50,  40,   0, 3 },
+        /* Focus   */ { 95,   0, 100, 4 },
+    };
+
+    private EinkPresetDefaults() {}
+
+    static String key(int slot, String field) {
+        return "eink_preset_" + slot + "_" + field;
+    }
+
+    static String defaultName(Context ctx, int slot) {
+        switch (slot) {
+            case 0: return ctx.getString(R.string.eink_preset_default_name_0);
+            case 1: return ctx.getString(R.string.eink_preset_default_name_1);
+            case 2: return ctx.getString(R.string.eink_preset_default_name_2);
+            case 3: return ctx.getString(R.string.eink_preset_default_name_3);
+            default: return "Preset " + slot;
+        }
+    }
+
+    static int defaultCold(int slot) { return DEFAULTS[slot][0]; }
+    static int defaultWarm(int slot) { return DEFAULTS[slot][1]; }
+    static int defaultKbd(int slot)  { return DEFAULTS[slot][2]; }
+    static int defaultMode(int slot) { return DEFAULTS[slot][3]; }
+
+    static String getName(Context ctx, ContentResolver cr, int slot) {
+        String s = Settings.System.getString(cr, key(slot, "name"));
+        return s != null ? s : defaultName(ctx, slot);
+    }
+
+    static int getCold(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "cold"), defaultCold(slot));
+    }
+
+    static int getWarm(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "warm"), defaultWarm(slot));
+    }
+
+    static int getKbd(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "kbd"), defaultKbd(slot));
+    }
+
+    static int getMode(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "mode"), defaultMode(slot));
+    }
+
+    static void resetSlot(ContentResolver cr, int slot) {
+        Settings.System.putString(cr, key(slot, "name"), null);
+        Settings.System.putInt(cr, key(slot, "cold"), defaultCold(slot));
+        Settings.System.putInt(cr, key(slot, "warm"), defaultWarm(slot));
+        Settings.System.putInt(cr, key(slot, "kbd"),  defaultKbd(slot));
+        Settings.System.putInt(cr, key(slot, "mode"), defaultMode(slot));
+    }
+
+    /** Refresh-mode integer to short label used in summaries. */
+    static String modeLabel(int mode) {
+        switch (mode) {
+            case 1: return "Clear";
+            case 2: return "A2 (alt)";
+            case 3: return "A2";
+            case 4: return "Speed";
+            default: return Integer.toString(mode);
+        }
+    }
+}
