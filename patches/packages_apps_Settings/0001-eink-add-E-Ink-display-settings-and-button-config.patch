@@ -0,0 +1,94 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.provider.Settings;
+
+import com.android.settings.R;
+
+/**
+ * Mirrors {@code com.android.systemui.eink.EinkPresetManager} default values and key naming.
+ * Both packages read/write the same Settings.System keys, so they always stay in sync.
+ *
+ * Cold values are display percentage (0-100); warm and kbd are 0-254 hardware units.
+ */
+final class EinkPresetDefaults {
+
+    /** {cold, warm, kbd, mode} — names come from string resources, see defaultName(). */
+    private static final int[][] DEFAULTS = {
+        /* Day     */ { 80,   0,   0, 1 },
+        /* Night   */ { 15, 120, 200, 3 },
+        /* Reading */ { 50,  40,   0, 3 },
+        /* Focus   */ { 95,   0, 100, 4 },
+    };
+
+    private EinkPresetDefaults() {}
+
+    static String key(int slot, String field) {
+        return "eink_preset_" + slot + "_" + field;
+    }
+
+    static String defaultName(Context ctx, int slot) {
+        switch (slot) {
+            case 0: return ctx.getString(R.string.eink_preset_default_name_0);
+            case 1: return ctx.getString(R.string.eink_preset_default_name_1);
+            case 2: return ctx.getString(R.string.eink_preset_default_name_2);
+            case 3: return ctx.getString(R.string.eink_preset_default_name_3);
+            default: return "Preset " + slot;
+        }
+    }
+
+    static int defaultCold(int slot) { return DEFAULTS[slot][0]; }
+    static int defaultWarm(int slot) { return DEFAULTS[slot][1]; }
+    static int defaultKbd(int slot)  { return DEFAULTS[slot][2]; }
+    static int defaultMode(int slot) { return DEFAULTS[slot][3]; }
+
+    static int getCold(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "cold"), defaultCold(slot));
+    }
+
+    static int getWarm(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "warm"), defaultWarm(slot));
+    }
+
+    static int getKbd(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "kbd"), defaultKbd(slot));
+    }
+
+    static int getMode(ContentResolver cr, int slot) {
+        return Settings.System.getInt(cr, key(slot, "mode"), defaultMode(slot));
+    }
+
+    static void resetSlot(ContentResolver cr, int slot) {
+        Settings.System.putInt(cr, key(slot, "cold"), defaultCold(slot));
+        Settings.System.putInt(cr, key(slot, "warm"), defaultWarm(slot));
+        Settings.System.putInt(cr, key(slot, "kbd"),  defaultKbd(slot));
+        Settings.System.putInt(cr, key(slot, "mode"), defaultMode(slot));
+    }
+
+    /** Convert 0-254 hardware (warm/kbd) to user-visible 0-100 percentage. */
+    static int toPct(int hw) {
+        return Math.round(Math.max(0, Math.min(254, hw)) * 100f / 254f);
+    }
+
+    /** Convert 0-100 percentage back to 0-254 hardware. */
+    static int toHw(int pct) {
+        return Math.round(Math.max(0, Math.min(100, pct)) * 254f / 100f);
+    }
+
+    /** Refresh-mode integer to short label used in summaries. */
+    static String modeLabel(int mode) {
+        switch (mode) {
+            case 1: return "Clear";
+            case 2: return "A2 (alt)";
+            case 3: return "A2";
+            case 4: return "Speed";
+            default: return Integer.toString(mode);
+        }
+    }
+}
