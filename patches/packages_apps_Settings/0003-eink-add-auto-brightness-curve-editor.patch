diff --git a/src/com/android/settings/display/eink/EinkAutoCurveDefaults.java b/src/com/android/settings/display/eink/EinkAutoCurveDefaults.java
new file mode 100644
index 00000000000..5377b07d092
--- /dev/null
+++ b/src/com/android/settings/display/eink/EinkAutoCurveDefaults.java
@@ -0,0 +1,58 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.content.ContentResolver;
+import android.provider.Settings;
+
+/**
+ * Mirrors {@code com.android.systemui.eink.EinkAutoCurves} on the Settings side.
+ * Both packages read/write the same Settings.System keys so they stay in sync
+ * without crossing module boundaries.
+ */
+final class EinkAutoCurveDefaults {
+
+    /** Lux thresholds. Same as SystemUI's EinkAutoCurves.LUX. */
+    static final int[] LUX = {0, 5, 30, 100, 300, 1000, 3000, 8000};
+
+    static final int[] DEFAULT_COLD = {20, 30, 45, 50, 40, 15,  5,  0};
+    static final int[] DEFAULT_WARM = {70, 60, 45, 30, 15,  5,  0,  0};
+    static final int[] DEFAULT_KBD  = {60, 50, 25, 10,  5,  0,  0,  0};
+
+    enum Curve {
+        COLD("eink_auto_cold_", DEFAULT_COLD),
+        WARM("eink_auto_warm_", DEFAULT_WARM),
+        KBD ("eink_auto_kbd_",  DEFAULT_KBD);
+
+        final String prefix;
+        final int[] defaults;
+
+        Curve(String prefix, int[] defaults) {
+            this.prefix = prefix;
+            this.defaults = defaults;
+        }
+    }
+
+    private EinkAutoCurveDefaults() {}
+
+    static String key(Curve c, int luxIndex) {
+        return c.prefix + LUX[luxIndex];
+    }
+
+    static int getValue(ContentResolver cr, Curve c, int luxIndex) {
+        return Settings.System.getInt(cr, key(c, luxIndex), c.defaults[luxIndex]);
+    }
+
+    static void setValue(ContentResolver cr, Curve c, int luxIndex, int value) {
+        Settings.System.putInt(cr, key(c, luxIndex), value);
+    }
+
+    static void resetCurve(ContentResolver cr, Curve c) {
+        for (int i = 0; i < LUX.length; i++) {
+            Settings.System.putInt(cr, key(c, i), c.defaults[i]);
+        }
+    }
+}
diff --git a/src/com/android/settings/display/eink/EinkAutoCurveEditFragment.java b/src/com/android/settings/display/eink/EinkAutoCurveEditFragment.java
new file mode 100644
index 00000000000..e70a9efcb5c
--- /dev/null
+++ b/src/com/android/settings/display/eink/EinkAutoCurveEditFragment.java
@@ -0,0 +1,95 @@
+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.app.AlertDialog;
+import android.content.ContentResolver;
+import android.os.Bundle;
+
+import androidx.preference.Preference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * Edits a single auto-brightness curve. Eight stepper rows correspond 1:1 to
+ * {@link EinkAutoCurveDefaults#LUX}; each stepper persists its value to a
+ * {@code eink_auto_<curve>_<lux>} key in Settings.System.
+ */
+public class EinkAutoCurveEditFragment extends SettingsPreferenceFragment
+        implements Preference.OnPreferenceChangeListener {
+
+    public static final String ARG_CURVE = "eink_auto_curve";
+
+    private EinkAutoCurveDefaults.Curve mCurve;
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_auto_curve_edit, rootKey);
+
+        Bundle args = getArguments();
+        String curveName = args != null ? args.getString(ARG_CURVE) : null;
+        mCurve = curveName != null
+                ? EinkAutoCurveDefaults.Curve.valueOf(curveName)
+                : EinkAutoCurveDefaults.Curve.COLD;
+
+        ContentResolver cr = getContext().getContentResolver();
+
+        for (int i = 0; i < EinkAutoCurveDefaults.LUX.length; i++) {
+            String prefKey = "eink_auto_lux_" + EinkAutoCurveDefaults.LUX[i];
+            StepperPreference p = findPreference(prefKey);
+            if (p == null) continue;
+            p.setValue(EinkAutoCurveDefaults.getValue(cr, mCurve, i));
+            p.setOnPreferenceChangeListener(this);
+            p.getExtras().putInt("luxIndex", i);
+        }
+
+        Preference reset = findPreference("eink_auto_curve_reset");
+        if (reset != null) {
+            reset.setOnPreferenceClickListener(p -> { confirmReset(); return true; });
+        }
+
+        getActivity().setTitle(curveTitleResId());
+    }
+
+    @Override
+    public boolean onPreferenceChange(Preference preference, Object newValue) {
+        Bundle extras = preference.getExtras();
+        if (extras == null) return false;
+        int luxIndex = extras.getInt("luxIndex", -1);
+        if (luxIndex < 0) return false;
+        EinkAutoCurveDefaults.setValue(getContext().getContentResolver(),
+                mCurve, luxIndex, (Integer) newValue);
+        return true;
+    }
+
+    private int curveTitleResId() {
+        switch (mCurve) {
+            case COLD: return R.string.eink_auto_curve_cold_title;
+            case WARM: return R.string.eink_auto_curve_warm_title;
+            case KBD:  return R.string.eink_auto_curve_kbd_title;
+        }
+        return R.string.eink_auto_curves_title;
+    }
+
+    private void confirmReset() {
+        new AlertDialog.Builder(getContext())
+                .setTitle(R.string.eink_auto_curve_reset_title)
+                .setMessage(R.string.eink_auto_curve_reset_summary)
+                .setNegativeButton(android.R.string.cancel, null)
+                .setPositiveButton(android.R.string.ok, (d, w) -> {
+                    EinkAutoCurveDefaults.resetCurve(getContext().getContentResolver(), mCurve);
+                    onCreatePreferences(null, null);
+                })
+                .show();
+    }
+
+    @Override
+    public int getMetricsCategory() {
+        return MetricsEvent.VIEW_UNKNOWN;
+    }
+}
