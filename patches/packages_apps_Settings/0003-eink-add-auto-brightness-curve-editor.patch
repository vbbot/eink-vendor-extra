+/*
+ * SPDX-FileCopyrightText: 2026 @vbbot
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.display.eink;
+
+import android.app.AlertDialog;
+import android.content.ContentResolver;
+import android.hardware.Sensor;
+import android.hardware.SensorEvent;
+import android.hardware.SensorEventListener;
+import android.hardware.SensorManager;
+import android.os.Bundle;
+
+import androidx.preference.Preference;
+
+import com.android.internal.logging.nano.MetricsProto.MetricsEvent;
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+/**
+ * Lists the three auto-brightness curves (cold, warm, keyboard). Each row opens
+ * {@link EinkAutoCurveEditFragment} with a curve-specific argument. A "Reset all"
+ * entry restores every curve to its built-in defaults. The first row is a live
+ * lux readout that previews the current curve outputs at the active ambient
+ * level — useful for tuning the curves while observing the sensor.
+ */
+public class EinkAutoCurvesFragment extends SettingsPreferenceFragment {
+
+    private static final long UI_UPDATE_INTERVAL_MS = 500L;
+
+    private SensorManager mSensorManager;
+    private Sensor mLightSensor;
+    private Preference mLiveLuxPref;
+    private float mLastLux = -1f;
+    private long  mLastUiUpdate = 0L;
+
+    @Override
+    public void onCreatePreferences(Bundle savedInstanceState, String rootKey) {
+        setPreferencesFromResource(R.xml.eink_auto_curves_list, rootKey);
+
+        mSensorManager = getContext().getSystemService(SensorManager.class);
+        mLightSensor = mSensorManager != null
+                ? mSensorManager.getDefaultSensor(Sensor.TYPE_LIGHT) : null;
+        mLiveLuxPref = findPreference("eink_auto_curves_live_lux");
+
+        Preference cold = findPreference("eink_auto_curve_cold");
+        if (cold != null) {
+            cold.getExtras().putString(EinkAutoCurveEditFragment.ARG_CURVE,
+                    EinkAutoCurveDefaults.Curve.COLD.name());
+        }
+        Preference warm = findPreference("eink_auto_curve_warm");
+        if (warm != null) {
+            warm.getExtras().putString(EinkAutoCurveEditFragment.ARG_CURVE,
+                    EinkAutoCurveDefaults.Curve.WARM.name());
+        }
+        Preference kbd = findPreference("eink_auto_curve_kbd");
+        if (kbd != null) {
+            kbd.getExtras().putString(EinkAutoCurveEditFragment.ARG_CURVE,
+                    EinkAutoCurveDefaults.Curve.KBD.name());
+        }
+
+        Preference resetAll = findPreference("eink_auto_curves_reset_all");
+        if (resetAll != null) {
+            resetAll.setOnPreferenceClickListener(p -> { confirmResetAll(); return true; });
+        }
+    }
+
+    @Override
+    public void onResume() {
+        super.onResume();
+        if (mSensorManager != null && mLightSensor != null) {
+            mSensorManager.registerListener(mLightListener, mLightSensor,
+                    SensorManager.SENSOR_DELAY_NORMAL);
+        } else if (mLiveLuxPref != null) {
+            mLiveLuxPref.setSummary("No ambient light sensor on this device");
+        }
+    }
+
+    @Override
+    public void onPause() {
+        super.onPause();
+        if (mSensorManager != null) mSensorManager.unregisterListener(mLightListener);
+    }
+
+    private final SensorEventListener mLightListener = new SensorEventListener() {
+        @Override
+        public void onSensorChanged(SensorEvent event) {
+            mLastLux = event.values[0];
+            long now = System.currentTimeMillis();
+            if (now - mLastUiUpdate >= UI_UPDATE_INTERVAL_MS) {
+                mLastUiUpdate = now;
+                refreshLiveLux();
+            }
+        }
+        @Override public void onAccuracyChanged(Sensor sensor, int accuracy) {}
+    };
+
+    private void refreshLiveLux() {
+        if (mLiveLuxPref == null || mLastLux < 0f) return;
+        ContentResolver cr = getContext().getContentResolver();
+        int cold = EinkAutoCurveDefaults.interpolate(cr, EinkAutoCurveDefaults.Curve.COLD, mLastLux);
+        int warm = EinkAutoCurveDefaults.interpolate(cr, EinkAutoCurveDefaults.Curve.WARM, mLastLux);
+        int kbd  = EinkAutoCurveDefaults.interpolate(cr, EinkAutoCurveDefaults.Curve.KBD,  mLastLux);
+        mLiveLuxPref.setSummary(String.format(
+                "%.1f lux  →  cold %d%%  ·  warm %d%%  ·  kbd %d%%",
+                mLastLux, cold, warm, kbd));
+    }
+
+    private void confirmResetAll() {
+        new AlertDialog.Builder(getContext())
+                .setTitle(R.string.eink_auto_curves_reset_all_title)
+                .setMessage(R.string.eink_auto_curves_reset_all_summary)
+                .setNegativeButton(android.R.string.cancel, null)
+                .setPositiveButton(android.R.string.ok, (d, w) -> {
+                    for (EinkAutoCurveDefaults.Curve c : EinkAutoCurveDefaults.Curve.values()) {
+                        EinkAutoCurveDefaults.resetCurve(getContext().getContentResolver(), c);
+                    }
+                    refreshLiveLux();
+                })
+                .show();
+    }
