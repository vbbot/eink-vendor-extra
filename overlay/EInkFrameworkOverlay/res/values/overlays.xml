<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Cap system brightness to the lcd-backlight sysfs node range (max_brightness=80).
         framework-res RROs only seem to apply to dimen/float resources for these brightness
         configs; integer overrides are silently ignored. Override all three floats so
         DisplayDeviceConfig.loadBrightnessConstraintsFromConfigXml takes the float branch
         (it requires BOTH min and max to be != -2). 0.31372549 = 80/255. -->
    <item name="config_screenBrightnessSettingMinimumFloat" format="float" type="dimen">0.0</item>
    <item name="config_screenBrightnessSettingMaximumFloat" format="float" type="dimen">0.31372549</item>
    <item name="config_screenBrightnessSettingDefaultFloat" format="float" type="dimen">0.15686275</item>

    <!-- Disable ripple/tap highlight effects — they cause ghosting on e-ink -->
    <item name="highlight_alpha_material_light" format="float" type="dimen">0.0</item>
    <item name="highlight_alpha_material_dark" format="float" type="dimen">0.0</item>
    <item name="highlight_alpha_material_colored" format="float" type="dimen">0.0</item>

    <!-- Neutral black/white Material3 system colour palette.
         With Monet disabled these static values take full effect: no FabricatedOverlay
         exists to override them. -->
    <color name="system_background_light">#FFFFFFFF</color>
    <color name="system_surface_light">#FFFFFFFF</color>
    <color name="system_surface_bright_light">#FFFFFFFF</color>
    <color name="system_surface_dim_light">#FFE8E8E8</color>
    <color name="system_surface_variant_light">#FFE0E0E0</color>
    <color name="system_under_surface_light">#FFFFFFFF</color>
    <color name="system_on_surface_light">#FF000000</color>
    <color name="system_on_surface_variant_light">#FF404040</color>
    <color name="system_on_surface_inverse_light">#FFFFFFFF</color>
    <color name="system_primary_light">#FF000000</color>
    <color name="system_on_primary_light">#FFFFFFFF</color>
    <color name="system_primary_container_light">#FFE0E0E0</color>
    <color name="system_on_primary_container_light">#FF000000</color>
    <color name="system_control_activated_light">#FF000000</color>
    <color name="system_control_normal_light">#FF606060</color>
    <color name="system_control_highlight_light">#FF000000</color>
    <color name="list_divider_opacity_material">#4D000000</color>

    <!-- E-Ink screensaver: register the SystemUI EinkDreamService as the device-default
         screensaver. Combined with PhoneWindowManager.startedGoingToSleep starting the dream
         on every sleep transition, this gives the device a single deterministic screensaver
         (moon + Zzz on white) that renders before the panel sleeps. -->
    <string name="config_dreamsDefaultComponent" translatable="false">com.android.systemui/com.android.systemui.eink.screensaver.EinkDreamService</string>

    <!-- E-Ink: register our screensaver dream as the doze component. PMS only allows dreams
         to run during ASLEEP wakefulness via the doze flow; a regular non-doze startDream
         call during startedGoingToSleep is torn down by handleSandman within ~30ms because
         dreams aren't allowed in ASLEEP state. By pointing config_dozeComponent at our
         dream, PMS itself starts our dream as part of the sleep transition (canDoze=true,
         reason='power manager request') and leaves it running until user wake. The dream
         doesn't actually call startDozing() — the e-ink panel persists the last frame
         natively without needing a low-power AOD mode. -->
    <string name="config_dozeComponent" translatable="false">com.android.systemui/com.android.systemui.eink.screensaver.EinkDreamService</string>

    <!-- Default home: pin RoleManager's HOME default to inkOS so on first boot
         RoleControllerService grants the HOME role to app.inkos. With Launcher3QuickStep
         still installed (it owns config_recentsComponentName), this prevents the launcher
         chooser from appearing while preserving the recents/gesture-nav provider. -->
    <string name="config_defaultHome" translatable="false">app.inkos</string>

    <!-- Quick Settings tile colours -->
    <color name="system_shade_active_light">#FF000000</color>
    <color name="system_shade_inactive_light">#FFE0E0E0</color>
    <color name="system_shade_disabled_light">#FFCCCCCC</color>
    <color name="system_on_shade_active_light">#FFFFFFFF</color>
    <color name="system_on_shade_active_variant_light">#FFE0E0E0</color>
    <color name="system_on_shade_inactive_light">#FF000000</color>
    <color name="system_on_shade_inactive_variant_light">#FF404040</color>
</resources>
