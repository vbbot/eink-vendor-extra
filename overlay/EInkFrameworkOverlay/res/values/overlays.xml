<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Cap system brightness to the lcd-backlight sysfs node range (max_brightness=80).
         framework-res RROs only seem to apply to dimen/float resources for these brightness
         configs; integer overrides are silently ignored. Override all three floats so
         DisplayDeviceConfig.loadBrightnessConstraintsFromConfigXml takes the float branch
         (it requires BOTH min and max to be != -2). 0.31372549 = 80/255. -->
    <item name="config_screenBrightnessSettingMinimumFloat" format="float" type="dimen">0.0</item>
    <item name="config_screenBrightnessSettingMaximumFloat" format="float" type="dimen">0.31372549</item>
    <item name="config_screenBrightnessSettingDefaultFloat" format="float" type="dimen">0.15686275</item>

    <!-- Disable ripple/tap highlight effects — they cause ghosting on e-ink -->
    <item name="highlight_alpha_material_light" format="float" type="dimen">0.0</item>
    <item name="highlight_alpha_material_dark" format="float" type="dimen">0.0</item>
    <item name="highlight_alpha_material_colored" format="float" type="dimen">0.0</item>

    <!-- Pure B/W Material3 system colour palette — no greys, no tints. EPD has poor grey
         ramp resolution and ages unevenly; mid-tones produce muddy fringes and persistent
         ghosting. With Monet disabled (frameworks_base/0003) these static values take full
         effect: no FabricatedOverlay exists to override them.

         Structure on EPD comes from 2dp strokes and 1dp dividers, NOT from fill differentiation,
         so every "surface variant" / "container" is the same white as the base surface.
         "Variant" foreground tokens stay solid black for the same reason. -->
    <color name="system_background_light">#FFFFFFFF</color>
    <color name="system_surface_light">#FFFFFFFF</color>
    <color name="system_surface_bright_light">#FFFFFFFF</color>
    <color name="system_surface_dim_light">#FFFFFFFF</color>
    <color name="system_surface_variant_light">#FFFFFFFF</color>
    <color name="system_under_surface_light">#FFFFFFFF</color>
    <color name="system_on_surface_light">#FF000000</color>
    <color name="system_on_surface_variant_light">#FF000000</color>
    <color name="system_on_surface_inverse_light">#FFFFFFFF</color>
    <color name="system_primary_light">#FF000000</color>
    <color name="system_on_primary_light">#FFFFFFFF</color>
    <color name="system_primary_container_light">#FFFFFFFF</color>
    <color name="system_on_primary_container_light">#FF000000</color>
    <color name="system_control_activated_light">#FF000000</color>
    <color name="system_control_normal_light">#FF000000</color>
    <color name="system_control_highlight_light">#FF000000</color>

    <!-- Material3 surface containers — flat white, no elevation tint.
         The stock palette reads light-lavender (#EDEDF6 etc.) and is what the QS shade
         chrome uses for its panel background; without these overrides the whole shade
         renders lavender even though system_surface_light is white. -->
    <color name="system_surface_container_lowest_light">#FFFFFFFF</color>
    <color name="system_surface_container_low_light">#FFFFFFFF</color>
    <color name="system_surface_container_light">#FFFFFFFF</color>
    <color name="system_surface_container_high_light">#FFFFFFFF</color>
    <color name="system_surface_container_highest_light">#FFFFFFFF</color>

    <!-- Material3 secondary/tertiary core tokens — used by FilledTonalButton, chips, etc.
         Tonal palettes below cover the _100/_200 container shades; these are the discrete
         non-tonal slots. -->
    <color name="system_secondary_light">#FF000000</color>
    <color name="system_on_secondary_light">#FFFFFFFF</color>
    <color name="system_secondary_container_light">#FFFFFFFF</color>
    <color name="system_on_secondary_container_light">#FF000000</color>
    <color name="system_tertiary_light">#FF000000</color>
    <color name="system_on_tertiary_light">#FFFFFFFF</color>
    <color name="system_tertiary_container_light">#FFFFFFFF</color>
    <color name="system_on_tertiary_container_light">#FF000000</color>

    <!-- Outlines — used as 1dp dividers in Material3 layouts. Solid black so they
         read as crisp hairlines on EPD. -->
    <color name="system_outline_light">#FF000000</color>
    <color name="system_outline_variant_light">#FF000000</color>

    <!-- Inverse surface / on_inverse — used by Snackbars, tooltips. Black bg, white text. -->
    <color name="system_inverse_surface_light">#FF000000</color>
    <color name="system_inverse_on_surface_light">#FFFFFFFF</color>
    <color name="system_inverse_primary_light">#FFFFFFFF</color>

    <!-- Error tokens — kept B/W, no red. Errors are communicated by icon (warning
         triangle) or text content; coloured states age unevenly on EPD and the user's
         aesthetic explicitly forbids non-B/W tints. -->
    <color name="system_error_light">#FF000000</color>
    <color name="system_on_error_light">#FFFFFFFF</color>
    <color name="system_error_container_light">#FFFFFFFF</color>
    <color name="system_on_error_container_light">#FF000000</color>

    <!-- Monet tonal palettes — accent1/2/3 + neutral1/2.
         Patch frameworks_base/0003 stops ThemeOverlayController from publishing a
         FabricatedOverlay derived from wallpaper colours, but the *static* defaults in
         frameworks/base/core/res/values/colors.xml remain blue-leaning (system_accent1_500
         = #6476A5 etc.). Anything that resolves colorAccent / colorPrimary via the
         legacy AppCompat path (e.g. com.android.shell BugreportWarningActivity) reads
         the static accent1 palette directly and renders blue.

         Binary cliff at _500: tones 0..400 → white (was tints/highlights), 500..1000 →
         black (was the actual accent + dark variants). Kills every lavender/blue
         derivation in a single sweep. The exact cliff position doesn't matter much
         once everything is B/W — what matters is the cliff is consistent across the
         three accent palettes so cross-references stay coherent. -->
    <color name="system_accent1_0_light">#FFFFFFFF</color>
