    <!-- E-Ink screensaver: register the SystemUI EinkDreamService as the device-default
         screensaver. Combined with PhoneWindowManager.startedGoingToSleep starting the dream
         on every sleep transition, this gives the device a single deterministic screensaver
         (moon + Zzz on white) that renders before the panel sleeps. -->
    <string name="config_dreamsDefaultComponent" translatable="false">com.android.systemui/com.android.systemui.eink.screensaver.EinkDreamService</string>

    <!-- E-Ink: register our screensaver dream as the doze component. PMS only allows dreams
         to run during ASLEEP wakefulness via the doze flow; a regular non-doze startDream
         call during startedGoingToSleep is torn down by handleSandman within ~30ms because
         dreams aren't allowed in ASLEEP state. By pointing config_dozeComponent at our
         dream, PMS itself starts our dream as part of the sleep transition (canDoze=true,
         reason='power manager request') and leaves it running until user wake. The dream
         doesn't actually call startDozing() — the e-ink panel persists the last frame
         natively without needing a low-power AOD mode. -->
    <string name="config_dozeComponent" translatable="false">com.android.systemui/com.android.systemui.eink.screensaver.EinkDreamService</string>

    <!-- Default home: pin RoleManager's HOME default to inkOS so on first boot
         RoleControllerService grants the HOME role to app.inkos. With Launcher3QuickStep
         still installed (it owns config_recentsComponentName), this prevents the launcher
         chooser from appearing while preserving the recents/gesture-nav provider. -->
    <string name="config_defaultHome" translatable="false">app.inkos</string>

    <!-- Quick Settings tile colours.
         Active = black fill / white text. Inactive = white fill / black text (the 2dp stroke
         and any glyph swap is added at the layout/drawable level in the SystemUI overlay).
         The single grey kept here is system_shade_disabled_light: in pure B/W there is no way
         to distinguish "off" from "disabled" via colour alone, and a hatched/striped drawable
         only reaches the few tiles that use a custom background. Light grey is the pragmatic
         fallback so disabled tiles read as "not interactive" rather than "off". -->
    <color name="system_shade_active_light">#FF000000</color>
    <color name="system_shade_inactive_light">#FFFFFFFF</color>
    <color name="system_shade_disabled_light">#FFCCCCCC</color>
    <color name="system_on_shade_active_light">#FFFFFFFF</color>
    <color name="system_on_shade_active_variant_light">#FFFFFFFF</color>
    <color name="system_on_shade_inactive_light">#FF000000</color>
    <color name="system_on_shade_inactive_variant_light">#FF000000</color>
